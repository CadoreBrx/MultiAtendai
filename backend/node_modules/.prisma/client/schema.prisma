generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mensagens     Mensagem[]
  agendamentos  Agendamento[]
  departamentos Departamento[] @relation("AgentesDoSetor")
  contatos      Contato[]      @relation("AtendentesDoContato")
}

model Departamento {
  id        String    @id @default(uuid())
  nome      String
  ordem     Int       @default(0) // Para a ordem no menu do bot (1, 2, 3...)
  cor       String?   @default("#6366f1")
  descricao String?
  agents    Usuario[] @relation("AgentesDoSetor")
  contatos  Contato[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Configuracao {
  id    String @id @default(uuid())
  chave String @unique // ex: 'welcomeMessage'
  valor String @default("")

  updatedAt DateTime @updatedAt
}

model Contato {
  id         String   @id @default(uuid())
  nome       String?
  numero     String   @unique
  fotoPerfil String?
  status     String   @default("lead") // lead, qualificado, negociacao, fechado, perdido
  chatStatus String   @default("pending") // pending (fila), active (atendendo), closed (encerrado)
  valor      Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  mensagens    Mensagem[]
  agendamentos Agendamento[]

  departamentoId String?
  departamento   Departamento? @relation(fields: [departamentoId], references: [id])

  atendenteId String?
  atendente   Usuario? @relation(fields: [atendenteId], references: [id], name: "AtendentesDoContato")
}

model Agendamento {
  id        String   @id @default(uuid())
  titulo    String
  descricao String?
  dataHora  DateTime
  status    String   @default("pendente") // pendente, concluido, cancelado

  contatoId String?
  contato   Contato? @relation(fields: [contatoId], references: [id])

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Mensagem {
  id         String  @id @default(uuid())
  whatsappId String  @unique
  corpo      String
  fromMe     Boolean @default(false)
  hasMedia   Boolean @default(false)
  timestamp  Int

  contatoId String
  contato   Contato @relation(fields: [contatoId], references: [id])

  usuarioId String?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])

  createdAt DateTime @default(now())
}
